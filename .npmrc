# Don't auto-install peer deps. vitest@4 pulls vite@8 whose peer dep on
# esbuild ^0.27 || ^0.28 would otherwise pull esbuild 0.28's platform
# binaries into the tree — including @esbuild/openharmony-arm64, which
# trips npm 11's platform-optional-dep bugs (npm/cli#4828, #7622, #8320).
# We don't actually use vite directly; vitest bundles its own runtime.
legacy-peer-deps=true
